# Flask runtime
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=change-me
DATABASE_URL=postgresql+psycopg://quote_requests:quote_requests@localhost:5432/quote_requests
TEST_DATABASE_URL=sqlite+pysqlite:///:memory:

# Feature flags
ENABLE_SCHEDULING=true
ENABLE_STAFF_MANAGEMENT=true
ENABLE_CUSTOMER_RECORDS=true
ENABLE_CALENDAR=true
ENABLE_RECURRING_WORK=true

# Spam protection (reCAPTCHA v3)
# For local development keys, add localhost and 127.0.0.1 as allowed domains.
RECAPTCHA_ENABLED=false
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5

# Branding and public site content
BUSINESS_NAME=Service Company
# Legacy alias; BUSINESS_NAME takes precedence when both are set.
# COMPANY_NAME=Service Company
TAGLINE=Clear estimates and straightforward service.
BUSINESS_PHONE=(555) 010-0200
BUSINESS_EMAIL=hello@example.com
SERVICE_AREA=your local service area
BUSINESS_ADDRESS=123 Service Lane, Suite 100
SITE_LOGO_PATH=assets/images/Logowhite.png
SITE_LOGO_ALT=
BUSINESS_SERVICES=Landscape Design,Roof Repair,Window Cleaning,Inspection,Painting,Deck Staining,Flooring,Siding,Fence Repair,General Maintenance

# Email
ADMIN_NOTIFICATION_EMAIL=admin@example.com
DEFAULT_FROM_EMAIL=noreply@example.com

# Social links and preview mode
SOCIAL_LINKS_PREVIEW=false
SOCIAL_FACEBOOK_ENABLED=false
SOCIAL_FACEBOOK_URL=
SOCIAL_INSTAGRAM_ENABLED=false
SOCIAL_INSTAGRAM_URL=
SOCIAL_LINKEDIN_ENABLED=false
SOCIAL_LINKEDIN_URL=
SOCIAL_YOUTUBE_ENABLED=false
SOCIAL_YOUTUBE_URL=
SOCIAL_X_ENABLED=false
SOCIAL_X_URL=
SOCIAL_TIKTOK_ENABLED=false
SOCIAL_TIKTOK_URL=
SOCIAL_PINTEREST_ENABLED=false
SOCIAL_PINTEREST_URL=
SOCIAL_WHATSAPP_ENABLED=false
SOCIAL_WHATSAPP_URL=
SOCIAL_TELEGRAM_ENABLED=false
SOCIAL_TELEGRAM_URL=
SOCIAL_SKYPE_ENABLED=false
SOCIAL_SKYPE_URL=
SOCIAL_SNAPCHAT_ENABLED=false
SOCIAL_SNAPCHAT_URL=
SOCIAL_SPOTIFY_ENABLED=false
SOCIAL_SPOTIFY_URL=
SOCIAL_REDDIT_ENABLED=false
SOCIAL_REDDIT_URL=
SOCIAL_GOOGLE_ENABLED=false
SOCIAL_GOOGLE_URL=
